.pytest_cache/
htmlcov/

# ── Trained-model artefacts (heavy, regeneratable) ──
# Reproduce via `poetry run python -m src.training.train …` or
# `python -m src.training.train_mtlm …` using the config.json saved
# alongside each run. The smaller JSON / CSV diagnostic files
# (config.json, train_log.csv, test_metrics.json, test_predictions.npz)
# stay in git so the head-to-head numbers and ensemble script can be
# audited without re-running.
*.pt
*.pt.weights
results/transformer/**/test_attn_weights.npz

# ── Claude Code ──
.claude/

# ── Misc ──
*.log
*.pdf
.env
CLAUDE.md

